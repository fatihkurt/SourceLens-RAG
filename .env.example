# --- LLM ---
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=llama3
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_MS=500
LLM_RETRY_MAX_MS=10000
MOCK_PLANNER=0

# --- Planner (optional override) ---
PLANNER_BASE_URL=
PLANNER_API_KEY=
PLANNER_MODEL=
PLANNER_TEMPERATURE=0

# --- Embedding ---
EMBED_PROVIDER=ollama
EMBED_BASE_URL=http://localhost:11434
EMBED_API_KEY=
EMBED_MODEL=nomic-embed-text

# --- Retrieval ---
TOP_K=3
TOP_N=300
MAX_HITS_PER_SOURCE=2
MAX_CONTEXT_CHARS=3500
DEBUG_RAG=0
LLM_RERANK_ENABLED=0
LLM_RERANK_POOL=10
LLM_RERANK_TEMPERATURE=0

# --- Answer ---
ANSWER_MAX_WORDS=100

# --- No-answer gate ---
NO_ANSWER_GATE_ENABLED=1
NO_ANSWER_MIN_TOP_SCORE=0.55
NO_ANSWER_MIN_GAP=0.02
NO_ANSWER_MIN_CONTEXT_CHARS=400
NO_ANSWER_ON_LOW_CONFIDENCE=1
NO_ANSWER_ON_FALLBACK=1
NO_ANSWER_SUGGEST_NARROWING=1
NO_ANSWER_MAX_NEARBY_SOURCES=2

# --- Cache ---
CACHE_ENABLED=1
CACHE_DIR=./cache
EMBED_CACHE_ENABLED=1
EMBED_CACHE_TTL_SEC=0
QUERY_CACHE_ENABLED=1
QUERY_CACHE_TTL_SEC=600

# --- Query enrichment ---
QUERY_ENRICHMENT=
QUERY_ENRICHMENT_ENABLED=0

# --- Eval ---
EVAL_MODE=0
EVAL_QUERY_ENRICHMENT=
EVAL_TEMPERATURE=0.2
EVAL_SLEEP_MS=0
EVAL_MAX_CASES=0

# --- Eval gate ---
EVAL_GATE_MAX_ERRORS=0
EVAL_GATE_MIN_HIT_RATE=1.0
EVAL_GATE_MIN_PREFER_HIT_RATE=1.0
EVAL_GATE_MAX_CONF_VIOLATION_RATE=0
EVAL_GATE_WARN_AVG_PROMPT_TOKENS=650
EVAL_GATE_WARN_AVG_LATENCY_MS=30000
EVAL_GATE_WARN_FALLBACK_USED_RATE=0.4
EVAL_GATE_WARN_ABSTAIN_RATE=0.5
