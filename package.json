{
  "name": "sourcelens-rag",
  "version": "1.0.0",
  "description": "SourceLens-RAG: production-focused RAG core and AI orchestration runtime for Node.js/TypeScript.",
  "private": false,
  "license": "MIT",
  "author": "Fatih Kurt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fatihkurt/SourceLens-RAG.git"
  },
  "bugs": {
    "url": "https://github.com/fatihkurt/SourceLens-RAG/issues"
  },
  "homepage": "https://github.com/fatihkurt/SourceLens-RAG#readme",
  "type": "module",
  "main": "src/app/cli/index.ts",
  "files": [
    "src",
    "docs",
    "eval",
    ".env.example",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "rag",
    "retrieval-augmented-generation",
    "ai-orchestration",
    "llm",
    "evaluation",
    "typescript",
    "nodejs"
  ],
  "scripts": {
    "eval": "node ./src/eval/run_answers.js ./eval/gold.json",
    "eval:gate": "npm run eval && node ./src/eval/gate.js ./eval/last_answers_report.json",
    "test": "tsx --test src/**/*.test.js src/**/*.test.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "ingest": "node ./src/ingest.js",
    "cli:ts": "tsx src/app/cli/index.ts",
    "server:ts": "tsx src/app/server/index.ts",
    "eval:ts": "tsx src/eval/run_eval.ts src/eval/datasets/cm.json",
    "cache:clear": "node ./src/scripts/clearCache.js",
    "cache:clear:queries": "node ./src/scripts/clearCache.js queries",
    "cache:clear:embeddings": "node ./src/scripts/clearCache.js embeddings",
    "index:rebuild": "node ./src/ingest.js --force",
    "index:rollback": "node ./src/scripts/indexRollback.js",
    "index:status": "node ./src/scripts/indexStatus.js"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2"
  }
}
